# DWD-API (Brightsky-Wrapper) braucht keinen Key
DWD_BASE_URL=https://api.brightsky.dev

# energy-charts (EPEX SPOT) – kein Key nötig
ENERGY_CHARTS_BASE_URL=https://api.energy-charts.info

# Default-Region für Wetterdaten (Würzburg, falls Marja nichts anderes sagt)
DEFAULT_LAT=49.7913
DEFAULT_LON=9.9534
DEFAULT_BIDDING_ZONE=DE-LU

# Cache-Verzeichnis für API-Antworten
CACHE_DIR=data/external
